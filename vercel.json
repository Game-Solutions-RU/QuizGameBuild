{
  "routes": [
    {
      "src": "/Build/(.*)\\.js\\.br$",
      "headers": {
        "Content-Encoding": "br",
        "Content-Type": "application/javascript"
      }
    },
    {
      "src": "/Build/(.*)\\.wasm\\.br$",
      "headers": {
        "Content-Encoding": "br",
        "Content-Type": "application/wasm"
      }
    },
    {
      "src": "/Build/(.*)\\.data\\.br$",
      "headers": {
        "Content-Encoding": "br",
        "Content-Type": "application/octet-stream"
      }
    }
  ]
}
